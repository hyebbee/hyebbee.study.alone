            `;
        }

        function buildFinancials(data) {
            const bars = data.financials.utilization.map(item => `
                <div class="mb-2.5">
                    <div class="flex justify-between text-xs font-medium text-stone-700 mb-1">
                        <span>${item.label}</span>
                        <span>${item.rate}%</span>
                    </div>
                    <div class="w-full bg-stone-200 rounded-full h-1.5">
                        <div class="h-1.5 rounded-full bg-${data.theme}-500" style="width: ${item.rate}%"></div>
                    </div>
                </div>
            `).join('');

            return `
                <section class="bg-white rounded-xl shadow-sm border border-stone-200 p-6 mb-6">
                    ${renderSectionIntro('1. 재무 지표 및 2026.1Q Update', '과거 매출/이익 트렌드와 함께 최신 증권사 리포트에서 지적한 단기 실적 관전 포인트를 확인합니다.')}
                    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 items-start">
                        <div class="lg:col-span-2">
                            <div class="chart-container">
                                <canvas id="finChart"></canvas>
                            </div>
                        </div>
                        <div class="flex flex-col gap-4">
                            <!-- 1Q Review Alert Box -->
                            <div class="bg-${data.theme}-50 border-l-4 border-${data.theme}-500 p-4 rounded-r-lg">
                                <h4 class="font-bold text-${data.theme}-800 text-sm mb-1 flex items-center gap-1">
                                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
                                    ${data.financials.q1Review.title}
                                </h4>
                                <p class="text-xs text-stone-700 leading-relaxed">${data.financials.q1Review.text}</p>
                            </div>
                            
                            <!-- Utilization Box -->
                            <div class="bg-stone-50 p-4 rounded-lg border border-stone-100">
                                <h3 class="text-sm font-bold text-stone-800 mb-2">🏭 가동률 점검</h3>
                                <p class="text-[11px] text-stone-500 mb-3 pb-2 border-b border-stone-200">${data.financials.productionText}</p>
                                ${bars}
                            </div>
                        </div>
                    </div>
                </section>
            `;
        }

        function buildValueChain(data) {
            const positions = [
                { id: 0, title: 'Upstream', desc: '광물/제련' },
                { id: 1, title: 'Midstream', desc: '배터리/소재/부품' },
                { id: 2, title: 'Downstream', desc: '완성차/모빌리티' }
            ];

            const nodes = positions.map(pos => {
                const isActive = pos.id === data.valueChain.position;
                const stateClass = isActive ? `vc-card-active border-2 border-${data.theme}-400 bg-${data.theme}-50` : 'vc-card-inactive border border-stone-200 bg-white';
                const textClass = isActive ? `text-${data.theme}-700` : 'text-stone-700';
                return `
                    <div class="vc-card flex-1 rounded-lg p-3 text-center ${stateClass}">
                        <h4 class="font-bold ${textClass} text-sm mb-1">${pos.title}</h4>
                        <p class="text-[11px] text-stone-500 hidden sm:block">${pos.desc}</p>
                    </div>
                `;
            }).join('<div class="hidden md:flex text-stone-300 px-1 text-sm">▶</div>');

            const checks = data.valueChain.checklist.map(item => `<li class="flex items-start text-xs text-stone-700 mb-1.5"><span class="text-${data.theme}-500 mr-2 text-[10px] mt-0.5">■</span><span>${item}</span></li>`).join('');

            return `
                <section class="bg-white rounded-xl shadow-sm border border-stone-200 p-6 mb-6">
                    ${renderSectionIntro('2. 밸류체인 입지 & 투자 체크리스트', '해당 기업의 산업 내 위치 및 2026년 기준 핵심 모니터링 지표입니다.')}
                    <div class="flex flex-col md:flex-row items-center justify-between mb-5 gap-2 md:gap-0">${nodes}</div>
                    <div class="bg-stone-50 rounded-lg p-4 border border-stone-200">
                        <ul class="pl-1">${checks}</ul>
                    </div>
                </section>
            `;
        }

        function buildCompetitiveness(data) {
            const cards = data.competitiveness.map(comp => `
                <div class="bg-white p-4 rounded-lg border border-stone-200 hover:border-${data.theme}-400 transition-colors shadow-sm">
                    <div class="text-xl mb-2">${comp.icon}</div>
                    <h4 class="font-bold text-stone-800 text-sm mb-1.5">${comp.title}</h4>
                    <p class="text-xs text-stone-600 leading-relaxed">${comp.desc}</p>
                </div>
            `).join('');

            return `
                <section class="bg-stone-50 rounded-xl p-6 mb-6 border border-stone-200">
                    ${renderSectionIntro('3. 중장기 핵심 모멘텀', '단기 실적을 넘어 밸류에이션 확장을 이끌어낼 구조적 성장 동력입니다.')}
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-4">${cards}</div>
                </section>
            `;
        }

        function buildTimeline(data) {
            const items = data.timeline.map(t => `
                <div class="timeline-item relative pl-5 pb-5 border-l-2 border-stone-300 text-${data.theme}-600 last:pb-0 last:border-transparent">
                    <div class="font-bold text-xs mb-1">${t.date}</div>
                    <div class="text-xs text-stone-700 bg-white p-2.5 rounded border border-stone-100">${t.text}</div>
                </div>
            `).join('');

            return `
                <section class="bg-white rounded-xl shadow-sm border border-stone-200 p-6 mb-6">
                    ${renderSectionIntro('4. 주요 이슈 타임라인', '최근 주요 경영 이벤트 및 외부 환경 변화에 대한 대응 흐름입니다.')}
                    <div class="ml-2 mt-4">${items}</div>
                </section>
            `;
        }

        function buildStrategy(data) {
            const points = data.strategy.points.map(p => `
                <li class="mb-2 pl-4 relative text-sm leading-relaxed text-stone-300">
                    <span class="absolute left-0 top-1.5 w-1.5 h-1.5 rounded-full bg-${data.theme}-400"></span>
                    ${p.replace(/투자 포인트:|리스크:|액션:/g, match => `<strong class="text-white">${match}</strong>`)}
                </li>
            `).join('');

            return `
                <section class="bg-stone-900 rounded-xl shadow-lg p-6 mb-6 border-t-4 border-${data.theme}-500">
                    <h2 class="text-lg font-bold text-white mb-4 flex items-center gap-2"><span class="text-xl">💡</span> 5. 2026 투자 전략 총평</h2>
                    <div class="bg-stone-800 rounded-lg p-4 mb-4 text-center border border-stone-700">
                        <strong class="text-lg md:text-xl text-${data.theme}-300 font-bold">"${data.strategy.outlook}"</strong>
                    </div>
                    <ul>${points}</ul>
                </section>
            `;
        }

        function renderChart(data) {
            const ctx = document.getElementById('finChart');
            if(!ctx) return;
            if (currentChart) currentChart.destroy();

            const colors = colorMap[data.theme];

            currentChart = new Chart(ctx, {
                type: 'bar',
                data: {
                    labels: data.financials.labels,
                    datasets: [
                        { type: 'bar', label: '매출액(조원)', data: data.financials.revenue, backgroundColor: 'rgba(168, 162, 158, 0.4)', borderColor: 'rgb(168, 162, 158)', borderWidth: 1, yAxisID: 'y' },
                        { type: 'line', label: '영업이익(조원)', data: data.financials.profit, backgroundColor: colors.border, borderColor: colors.border, borderWidth: 3, pointBackgroundColor: '#fff', pointBorderColor: colors.border, pointRadius: 4, tension: 0.3, yAxisID: 'y1' }
                    ]
                },
                options: {
                    responsive: true, maintainAspectRatio: false,
                    interaction: { mode: 'index', intersect: false },
                    plugins: { legend: { position: 'top', labels: { usePointStyle: true, boxWidth: 6, font: { family: 'Pretendard', size: 11 } } }, tooltip: { backgroundColor: 'rgba(28, 25, 23, 0.9)', padding: 10 } },
                    scales: {
                        x: { grid: { display: false }, ticks: { font: { size: 10 } } },
                        y: { type: 'linear', display: true, position: 'left', title: { display: true, text: '매출', font: { size: 10 } }, grid: { color: 'rgba(231, 229, 228, 0.6)' }, ticks: { font: { size: 10 } } },
                        y1: { type: 'linear', display: true, position: 'right', title: { display: true, text: '이익', font: { size: 10 } }, grid: { drawOnChartArea: false }, ticks: { font: { size: 10 } } }
                    }
                }
            });
        }

        function loadCompany(companyId) {
            const data = db[companyId];
            if(!data) return;

            document.querySelectorAll('.tab-btn').forEach(btn => {
                if (btn.getAttribute('data-target') === companyId) {
                    btn.className = `tab-btn px-4 py-2 text-sm font-medium rounded-md transition-all bg-white shadow-sm border-b-2 text-${data.theme}-700 border-${data.theme}-600`;
                } else {
                    btn.className = `tab-btn px-4 py-2 text-sm font-medium rounded-md transition-all text-stone-600 hover:text-stone-900`;
                }
            });

            const container = document.getElementById('app-container');
            container.classList.remove('fade-enter');
            void container.offsetWidth; 

            container.innerHTML = `
                ${buildHeader(data)}
                ${buildFinancials(data)}
                ${buildValueChain(data)}
                <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
                    ${buildCompetitiveness(data)}
                    ${buildTimeline(data)}
                </div>
                ${buildStrategy(data)}
            `;

            container.classList.add('fade-enter');
            renderChart(data);
        }

        document.addEventListener('DOMContentLoaded', () => {
            document.getElementById('nav-tabs').addEventListener('click', (e) => {
                if(e.target.classList.contains('tab-btn')) loadCompany(e.target.getAttribute('data-target'));
            });
            loadCompany('hyundai'); // Default load
        });
    </script>
</body>
</html>
